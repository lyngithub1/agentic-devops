# ============================================================================
# Agentic DevOps — Live mode (LLM) configuration
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in ONE provider. These values are read
# server-side by the Vite dev proxy (src key never reaches the browser bundle).
# Live mode requires the dev server: `npm run dev`.
# ============================================================================

# --- Option A: Azure OpenAI (preferred) -------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_API_KEY=your-azure-openai-key
#
# Auth: provide AZURE_OPENAI_API_KEY above, OR use Entra ID (no key) by setting
# AZURE_OPENAI_USE_AAD=true and running `az login`. The proxy then calls
# `az account get-access-token` so your RBAC role (e.g. "Cognitive Services
# OpenAI User") is used. AAD is assumed automatically if no key is set.
# AZURE_OPENAI_USE_AAD=true
#
# If the endpoint lives in a different tenant than your active `az` subscription,
# pin the token to the right subscription (id or name):
# AZURE_OPENAI_AAD_SUBSCRIPTION=your-subscription-id-or-name
#
# Notes:
# - gpt-5 / o-series deployments need a recent API version (e.g. 2025-04-01-preview)
#   and the proxy automatically sends `max_completion_tokens` instead of `max_tokens`.
# - gpt-4.1 is a fast, non-reasoning option and works well for live mode.

# --- Option B: OpenAI --------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Optional: multi-model registry (runtime toggle in the UI)
# ----------------------------------------------------------------------------
# Define two or more model profiles and the Header shows a toggle to switch
# between them per run. Each profile <id> uses the SAME variable names as the
# single-provider options above, but prefixed with LLM_MODEL_<id>_.
# If LLM_MODELS is unset, the flat single-provider config above is used.
#
# LLM_MODELS=fast,deep
# LLM_DEFAULT_MODEL=fast
#
# LLM_MODEL_fast_LABEL=GPT-4.1
# LLM_MODEL_fast_DESCRIPTION=Fast · non-reasoning
# LLM_MODEL_fast_AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
# LLM_MODEL_fast_AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# LLM_MODEL_fast_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# LLM_MODEL_fast_AZURE_OPENAI_USE_AAD=true
# LLM_MODEL_fast_AZURE_OPENAI_AAD_SUBSCRIPTION=your-subscription-id-or-name
#
# LLM_MODEL_deep_LABEL=GPT-5.4
# LLM_MODEL_deep_DESCRIPTION=Deep reasoning · slower
# LLM_MODEL_deep_AZURE_OPENAI_ENDPOINT=https://other-resource.cognitiveservices.azure.com
# LLM_MODEL_deep_AZURE_OPENAI_DEPLOYMENT=gpt-5.4
# LLM_MODEL_deep_AZURE_OPENAI_API_VERSION=2025-04-01-preview
# LLM_MODEL_deep_AZURE_OPENAI_USE_AAD=true
# LLM_MODEL_deep_AZURE_OPENAI_AAD_SUBSCRIPTION=other-subscription-id

# ============================================================================
# Optional: GitHub live mode (Phase 2) — real branches, commits & pull requests
# ----------------------------------------------------------------------------
# When configured, the Validator phase can create a REAL branch, commit the
# generated code, and open a REAL pull request in your repo (then surface live
# check-run status). These values are read ONLY by the dev proxy
# (vite.github-proxy.ts) and never reach the browser bundle.
#
# Target repository (owner/repo):
# GITHUB_REPO=lyngithub1/agentic-devops
#
# --- Auth option A: fine-grained PAT (simplest for local dev) ----------------
# Create at https://github.com/settings/personal-access-tokens with access to
# ONLY this repo and these repository permissions:
#   Contents: Read and write · Pull requests: Read and write · Checks: Read ·
#   Metadata: Read
# GITHUB_PAT=github_pat_xxx
#
# --- Auth option B: GitHub App (recommended for shared/prod) ------------------
# Install a GitHub App on the repo with the same permissions, then supply:
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
#   (the private key may use literal \n in place of newlines)

