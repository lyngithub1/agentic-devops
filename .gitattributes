# Normalize line endings: stored as LF in the repo, checked out per-platform.
* text=auto eol=lf

# Windows-native scripts keep CRLF on checkout.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Shell scripts must always be LF.
*.sh text eol=lf

# Treat common binary assets as binary (no EOL conversion / diffing).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
